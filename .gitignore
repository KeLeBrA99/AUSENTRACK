# Archivos de migraciones compilados
*.pyc

# Variables de entorno
sigi_backend/.env
sigi_backend/.env.local
sigi_backend/.env.production

# Archivos de coleccion estatica
sigi_backend/staticfiles/
sigi_backend/static/

# Logs
sigi_backend/*.log
sigi_backend/logs/


